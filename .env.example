# Copy to `.env` and adjust. Pydantic Settings reads env vars (see `app/core/config.py`).

# --- App ---
APP_NAME=layer-gateway-api-v1
SERVICE_NAME=gateway-api
ENV=dev

# Model name on assistant messages + message_feedback when upstream omits it (recommended)
CHAT_ASSISTANT_MODEL=qwen2.5-7b
# Persist messages.status (requires ``status text`` column in Supabase; default off)
# CHAT_PERSIST_MESSAGE_STATUS=true

MAX_INFLIGHT_REQUESTS=16

# Chat backpressure (POST /v1/chat only; set to 0 to disable a limit)
MAX_CONCURRENT_CHAT_STREAMS=8
MAX_CONCURRENT_STREAMS_PER_USER=2
RATE_LIMIT_CHAT_REQUESTS_PER_MIN=6
RATE_LIMIT_CHAT_BURST=2

# --- Orchestrator (matches downstream: POST /v1/orchestrator/answer, POST /feedback) ---
ORCHESTRATOR_BASE_URL=http://192.168.86.179:30184
ORCHESTRATOR_CHAT_PATH=/v1/orchestrator/answer
ORCHESTRATOR_FEEDBACK_PATH=/feedback
ORCHESTRATOR_CONTRACT=flat_headers
ORCHESTRATOR_TIMEOUT_MS=120000
ORCHESTRATOR_RETRY_MAX_ATTEMPTS=2
ORCHESTRATOR_READINESS_PATH=/health
ORCHESTRATOR_READINESS_TIMEOUT_MS=3000
ORCHESTRATOR_READINESS_PROBE_ENABLED=true

# --- Auth (Supabase primary) ---
# Protected routes verify Bearer tokens via Supabase Auth + profiles when both are set:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Server-only service_role secret (NOT the anon/publishable key). Required for username→email
# lookup unless you run sql/username_login.sql in Supabase.
# SUPABASE_SERVICE_KEY=your-service-role-key
# Alias also accepted: SUPABASE_SERVICE_ROLE_KEY

# Web app origin for password-reset emails. Must match layer-web-v1 APP_URL and Supabase Dashboard
# → Authentication → URL configuration:
#   Site URL      = FRONTEND_URL (e.g. http://192.168.86.179:30186)
#   Redirect URLs = {FRONTEND_URL}/auth/reset-password
FRONTEND_URL=http://192.168.86.179:30186
# Optional extra origins the web BFF may send (comma-separated)
# ADDITIONAL_FRONTEND_URLS=http://localhost:3000

# Match Supabase Dashboard → Authentication → JWT expiry
JWT_EXPIRY_SECONDS=3600

# --- Auth (JWKS fallback when SUPABASE_* is unset) ---
# AUTH_JWT_ISSUER=https://your-idp.example/
# AUTH_JWT_AUDIENCE=api://your-resource-id
# AUTH_JWT_JWKS_URL=https://your-idp.example/.well-known/jwks.json
# AUTH_JWT_ALGORITHMS=RS256,ES256
# AUTH_JWT_CLAIM_USER_ID=sub
# AUTH_JWT_CLAIM_TENANT_ID=tenant_id
# AUTH_JWT_DEFAULT_TENANT_ID=
# AUTH_JWT_CLAIM_ROLES=roles
# AUTH_JWT_CLAIM_GROUPS=groups
# AUTH_JWT_CLAIM_TEAMS=teams

# --- Chat ---
CHAT_MESSAGE_MAX_LENGTH=4000
