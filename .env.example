# Copy to `.env` and adjust. Pydantic Settings reads env vars (see `app/core/config.py`).

# --- App ---
APP_NAME=layer-gateway-api-v1
SERVICE_NAME=gateway-api
ENV=dev

MAX_INFLIGHT_REQUESTS=100

# --- Orchestrator (matches downstream: POST /orchestrator/answer, POST /feedback) ---
ORCHESTRATOR_BASE_URL=http://192.168.86.179:30184
ORCHESTRATOR_CHAT_PATH=/orchestrator/answer
ORCHESTRATOR_FEEDBACK_PATH=/feedback
ORCHESTRATOR_CONTRACT=flat_headers
ORCHESTRATOR_TIMEOUT_MS=15000
ORCHESTRATOR_RETRY_MAX_ATTEMPTS=2
ORCHESTRATOR_READINESS_PATH=/health
ORCHESTRATOR_READINESS_TIMEOUT_MS=3000
ORCHESTRATOR_READINESS_PROBE_ENABLED=true

# --- Auth ---
# stub = local/dev: any non-empty Bearer token; trusted identity from AUTH_STUB_* (not from the token).
# jwt = production: verify OIDC access token (RS256/ES256 default) via JWKS; identity from JWT claims.
# AUTH_MODE=stub | jwt
AUTH_MODE=stub
#
# --- Stub auth (when AUTH_MODE=stub) ---
# Trusted user/tenant/roles for orchestrator auth + flat_headers X-User-* forwarding.
AUTH_STUB_USER_ID=taixing
AUTH_STUB_TENANT_ID=tenant_01
AUTH_STUB_ROLES=hr
AUTH_STUB_GROUPS=engineering
AUTH_STUB_TEAMS=rag-platform
#
# --- JWT auth (when AUTH_MODE=jwt; all three required) ---
# Copy issuer, API audience, and JWKS URL from your IdP’s OIDC discovery document.
# AUTH_MODE=jwt
# AUTH_JWT_ISSUER=https://your-idp.example/
# AUTH_JWT_AUDIENCE=api://your-resource-id
# AUTH_JWT_JWKS_URL=https://your-idp.example/.well-known/jwks.json
# Optional:
# AUTH_JWT_ALGORITHMS=RS256,ES256
# AUTH_JWT_CLAIM_USER_ID=sub
# AUTH_JWT_CLAIM_TENANT_ID=tenant_id
# AUTH_JWT_DEFAULT_TENANT_ID=
# AUTH_JWT_CLAIM_ROLES=roles
# AUTH_JWT_CLAIM_GROUPS=groups
# AUTH_JWT_CLAIM_TEAMS=teams

# --- Chat ---
CHAT_MESSAGE_MAX_LENGTH=4000
